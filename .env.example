# PostgreSQL connection string.
# Matches the docker-compose.yml defaults; change if you customized the compose file.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_documents

# OpenRouter API key. Create one at https://openrouter.ai/keys
# Required for the chat endpoint. Document upload and indexing work without it.
OPENROUTER_API_KEY=

# Chat model served through OpenRouter.
# Any chat-completions model on https://openrouter.ai/models works.
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# Port for the NestJS API.
PORT=3001

# Origin allowed by the API CORS policy (the Next.js dev server by default).
CORS_ORIGIN=http://localhost:3000

# Base URL of the API, consumed by the Next.js frontend.
NEXT_PUBLIC_API_URL=http://localhost:3001
